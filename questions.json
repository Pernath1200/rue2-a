{
  "present_simple": {
    "set1": {
      "title": "Present Simple – Practice",
      "summary": "Choose the correct form of the verb.",
      "questions": [
        {"type": "mc", "question": "She _____ coffee every morning.", "options": {"a": "drink", "b": "drinks", "c": "drinking", "d": "to drink"}, "correct_option": "b", "explanation": "With she we add -s."},
        {"type": "mc", "question": "_____ you like tea?", "options": {"a": "Do", "b": "Does", "c": "Is", "d": "Are"}, "correct_option": "a", "explanation": "With you we use Do."},
        {"type": "mc", "question": "He _____ work on Sundays.", "options": {"a": "don't", "b": "doesn't", "c": "not", "d": "no"}, "correct_option": "b", "explanation": "With he we use doesn't."},
        {"type": "mc", "question": "They _____ in London.", "options": {"a": "live", "b": "lives", "c": "living", "d": "to live"}, "correct_option": "a", "explanation": "With they we use the base form."},
        {"type": "mc", "question": "_____ she work here?", "options": {"a": "Do", "b": "Does", "c": "Is", "d": "Are"}, "correct_option": "b", "explanation": "With she we use Does."},
        {"type": "mc", "question": "I _____ like milk.", "options": {"a": "don't", "b": "doesn't", "c": "am not", "d": "not"}, "correct_option": "a", "explanation": "With I we use don't."},
        {"type": "mc", "question": "My brother _____ football.", "options": {"a": "play", "b": "plays", "c": "playing", "d": "to play"}, "correct_option": "b", "explanation": "He/she/it: plays."},
        {"type": "mc", "question": "We _____ to the gym every week.", "options": {"a": "go", "b": "goes", "c": "going", "d": "to go"}, "correct_option": "a", "explanation": "With we we use go."},
        {"type": "mc", "question": "The shop _____ at 9 am.", "options": {"a": "open", "b": "opens", "c": "opening", "d": "to open"}, "correct_option": "b", "explanation": "The shop = it. Opens."},
        {"type": "mc", "question": "_____ they speak English?", "options": {"a": "Do", "b": "Does", "c": "Is", "d": "Are"}, "correct_option": "a", "explanation": "With they we use Do."}
      ]
    }
  },
